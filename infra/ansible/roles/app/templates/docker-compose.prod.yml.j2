services:
  db:
    image: ghcr.io/aet-devops26/team-http-418/db:{{ image_tag }}
    environment:
      POSTGRES_PASSWORD: "{{ db_password }}"
      POSTGRES_USER: "postgres"
      COURSES_DB_NAME: "courses-data"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  db-seed:
    image: ghcr.io/aet-devops26/team-http-418/db:{{ image_tag }}
    command: ["seed-courses"]
    profiles: ["maintenance"]
    environment:
      DB_HOST: db
      DB_PORT: "5432"
      DB_USER: "postgres"
      DB_PASS: "{{ db_password }}"
      COURSES_DB_NAME: "courses-data"
    depends_on:
      db:
        condition: service_healthy

  server:
    image: ghcr.io/aet-devops26/team-http-418/server:{{ image_tag }}
    env_file: .env
    depends_on:
      db:
        condition: service_healthy
    restart: unless-stopped

  client:
    image: ghcr.io/aet-devops26/team-http-418/client:{{ image_tag }}
    ports:
      - "80:80"
    depends_on:
      - server
    restart: unless-stopped

  user-profile-service:
    image: ghcr.io/aet-devops26/team-http-418/user-profile-service:{{ image_tag }}
    expose:
      - "8080"
    env_file: .env
    depends_on:
      db:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8080/v1/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  pdf-parser:
    image: ghcr.io/aet-devops26/team-http-418/pdf-parser:{{ image_tag }}
    expose:
      - "8080"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8080/v1/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

volumes:
  pgdata:
