SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password
API_VERSION=v1

APP_JWT_ACCESS_TOKEN_TTL_SECONDS=3600
APP_REFRESH_TOKEN_TTL_SECONDS=604800
APP_JWT_SECRET=change-me-change-me-change-me-change-me

DB_HOST=db
DB_USER=postgres
DB_PASS=password
COURSES_DB_NAME=courses-data
DB_PORT=5432
SCRAPER_PROGRAM_IDS=5371,5217,5028,5000,4999,4997
SCRAPER_SEMESTER_IDS=205,206

# Frontend: set to "true" to use mock API responses, leave empty for real backend
VITE_MOCK_API=true

# Internal service URLs (Docker network hostnames — dev-start.sh overrides to localhost)
GENAI_BASE_URL=http://genai:8000
GENAI_API_VERSION=v1
GENAI_SERVICE_URL=http://genai:8000/v1
PROFILE_SERVICE_URL=http://user-profile-service:8080/v1
PDF_PARSER_SERVICE_URL=http://pdf-parser:8080/v1

# LLM provider: "cloud" (Logos, requires TUM network/eduVPN) or "local" (Ollama)
LLM_PROVIDER=cloud

# Cloud — Logos (TUM OpenAI-compatible API)
# Get your lg-... key from your tutor. Requires TUM network or eduVPN.
LOGOS_BASE_URL=https://logos.aet.cit.tum.de
LOGOS_API_VERSION=v1
LOGOS_API_KEY=lg-...
LOGOS_MODEL=openai/gpt-oss-120b

# Local — Ollama (run with: docker compose --profile local up)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Embedding models — used for semantic search + recommendations vector pipeline
# Cloud: Qwen/Qwen3-Embedding-8B via Logos (4096 dims)
# Local: nomic-embed-text via Ollama (768 dims)
EMBEDDING_MODEL_CLOUD=Qwen/Qwen3-Embedding-8B
EMBEDDING_MODEL_LOCAL=nomic-embed-text

# PostgreSQL connection for GenAI service (vector + course data)
# Uses courses-data DB — same DB scraper populates, embeddings stored alongside course data
DATABASE_URL=postgresql://postgres:password@db:5432/courses-data

# Transcript import: set to "true" to use AI (genAI embedding search) for unmatched modules
TRANSCRIPT_USE_AI=false
