SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

DB_HOST=db
DB_USER=postgres
DB_PASS=password
COURSES_DB_NAME=courses-data
DB_PORT=5432

# Frontend: set to "true" to use mock API responses, leave empty for real backend
VITE_MOCK_API=true

# GenAI service URL (internal Docker network — not exposed to host)
GENAI_BASE_URL=http://genai:8000/v1

# LLM provider: "cloud" (Logos, requires TUM network/eduVPN) or "local" (Ollama)
LLM_PROVIDER=cloud

# Cloud — Logos (TUM OpenAI-compatible API)
# Get your lg-... key from your tutor. Requires TUM network or eduVPN.
LOGOS_BASE_URL=https://logos.aet.cit.tum.de
LOGOS_API_KEY=lg-...
LOGOS_MODEL=openai/gpt-oss-120b

# Local — Ollama (run with: docker compose --profile local up)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
