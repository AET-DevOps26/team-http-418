services:
  db:
    image: postgres:17
    environment:
      POSTGRES_PASSWORD: "{{ db_password }}"
      POSTGRES_DB: "aidan"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  server:
    image: ghcr.io/aet-devops26/team-http-418/server:{{ image_tag }}
    env_file: .env
    depends_on:
      db:
        condition: service_healthy
    restart: unless-stopped

  client:
    image: ghcr.io/aet-devops26/team-http-418/client:{{ image_tag }}
    ports:
      - "80:80"
    depends_on:
      - server
    restart: unless-stopped

volumes:
  pgdata:
